# Local development environment for IDS AI Skeleton (macOS)
# Generated from .env.example + docs/setup/get-started-with-ids-ai-skeleton.md

# Logto PostgreSQL configuration
LOGTO_DB_HOST=localhost
LOGTO_DB_PORT=5432
LOGTO_DB_HOST_PORT=5433
LOGTO_DB_USER=postgres
LOGTO_DB_PASSWORD=devpassword
LOGTO_DB_NAME=logto_db

# IDS app RavenDB configuration
RAVENDB_URL=http://localhost:3333
RAVENDB_DATABASE=ids_dms
RAVENDB_PORT=3333

# API Server Port
IDS_ASTRA_APIS_PORT=3000

# MSSQL (optional local service; currently commented in docker-compose)
MSSQL_SA_PASSWORD=msSql!p_w_d

# Application Environment
NODE_ENV=development

# Logto Endpoint (used by backend and sync scripts)
LOGTO_ENDPOINT=http://localhost:3001

# Logto M2M Application Credentials for astra-apis -> Logto M2M app
LOGTO_M2M_APP_ID=izvpq3u28ztgpc9h80nt3
LOGTO_M2M_APP_SECRET="#internal:QcFz5zv4NyDCmlecyViB9Mw2QEtmHhXo"

# Logto Client Web Application (VITE_ prefix exposes to browser)
VITE_LOGTO_ENDPOINT=http://localhost:3001
VITE_LOGTO_APP_ID=ba88xzy7rap9hwk9m2di7

# Logto E2E API Testing
LOGTO_ISSUER=http://localhost:3001/oidc
LOGTO_APP_ID=ba88xzy7rap9hwk9m2di7

# Known test user from local Logto seed
TEST_USER_EMAIL=alice@acme-rv.com
TEST_USER_PASSWORD=xyab12dE

# Query Limits
MAX_API_QUERY_LIMIT=3000
MAX_DB_QUERY_LIMIT=3000

# Nx Terminal UI — disable the split-pane TUI for plain streaming logs
NX_TUI=false

# IDS Doctor — decoupled dev sidecar (never set in production)
VITE_ENABLE_IDS_DOCTOR=false
IDS_DOCTOR_PORT=3999
DOCTOR_CORS_ORIGIN=http://localhost:3004
VITE_DOCTOR_URL=http://localhost:3999
