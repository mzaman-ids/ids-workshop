# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings
.ai-plan/**

# System Files
.DS_Store
Thumbs.db

.nx/cache
.nx/workspace-data
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

vite.config.*.timestamp*
vitest.config.*.timestamp*
test-output

# Environment variables
# Ignore local overrides but allow committed defaults
.env.local
.env.*.local
.env.backup*
.env

mssql/

# Logto database backups (may contain secrets)
logto/backup/*.sql
!logto/backup/baseline.sql
!logto/backup/README.md

# Playwright test reports and artifacts
apps/client-web-e2e/playwright-report/
apps/client-web-e2e/test-results/
docs/training/training/*.pdf
docs/training/training/*.pptx
docs/mockups/
ui_mocks/

# API testing files with tokens (security - tokens should never be committed)
api-test.http
.claude/settings.local.json
azure/update-my-ip.sh
tsconfig.tsbuildinfo
*.lock
.claude/scheduled_tasks.lock

# IDS Doctor runtime files — contain JWT tokens, never commit
.doctor/sessions/
.doctor/alerts.jsonl
.doctor/diagnoses/
.doctor/snapshot.json
.doctor/requests/
.doctor/responses/
